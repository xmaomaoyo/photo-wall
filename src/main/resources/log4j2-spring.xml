<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <!-- 日志格式 -->
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <!-- 日志文件路径 -->
        <Property name="LOG_PATH">logs</Property>
        <!-- 应用名称 -->
        <Property name="APP_NAME">photo-wall</Property>
    </Properties>

    <Appenders>
        <!-- 控制台输出 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <!-- 只输出INFO及以上级别 -->
            <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>

        <!-- 应用日志文件 -->
        <RollingFile name="AppLog"
                     fileName="${LOG_PATH}/${APP_NAME}.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <!-- 按大小滚动：每10MB一个文件 -->
                <SizeBasedTriggeringPolicy size="10 MB"/>
                <!-- 按天滚动 -->
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <!-- 最多保留30个文件 -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- 错误日志单独记录 -->
        <RollingFile name="ErrorLog"
                     fileName="${LOG_PATH}/${APP_NAME}-error.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Filters>
                <!-- 只记录ERROR级别 -->
                <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- SQL日志（MyBatis-Plus） -->
        <RollingFile name="SqlLog"
                     fileName="${LOG_PATH}/${APP_NAME}-sql.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-sql-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- 应用日志 -->
        <Logger name="com.mimi.photowall" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppLog"/>
            <AppenderRef ref="ErrorLog"/>
        </Logger>

        <!-- MyBatis-Plus SQL日志 -->
        <Logger name="com.baomidou.mybatisplus" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="SqlLog"/>
        </Logger>

        <!-- MyBatis SQL日志 -->
        <Logger name="org.apache.ibatis" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="SqlLog"/>
        </Logger>

        <!-- Spring框架日志 -->
        <Logger name="org.springframework" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppLog"/>
        </Logger>

        <!-- 根日志 -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppLog"/>
            <AppenderRef ref="ErrorLog"/>
        </Root>
    </Loggers>
</Configuration>